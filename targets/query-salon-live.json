{
  "id": "query-salon-live",
  "type": "web",
  "entry": "https://querysalon.com",
  "flows": [
    "marketing",
    "quick-login"
  ],
  "max_attempts": 5,
  "preflight": {
    "screenGenie": {
      "requirements": [
        {
          "type": "http",
          "url": "https://querysalon.com/",
          "expected_status": [200]
        }
      ]
    },
    "voltmeter": {
      "requirements": [
        {
          "type": "http",
          "url": "https://api.querysalon.com/api/health",
          "method": "GET",
          "expected_status": [200]
        }
      ]
    }
  },
  "pointer": {
    "mode": "read_latest",
    "latest_run": "/Users/dannybrooking/Documents/GitHub = master copy/Pointer/state/latest-run.json"
  },
  "screenGenie": {
    "mode": "flows_latest",
    "commands": [
      "cd '/Users/dannybrooking/Documents/GitHub = master copy/ScreenGenie' && npm run genie -- --app query-salon-live --flow marketing",
      "cd '/Users/dannybrooking/Documents/GitHub = master copy/ScreenGenie' && npm run genie -- --app query-salon-live --flow quick-login"
    ],
    "latest_runs": [
      "/Users/dannybrooking/Documents/GitHub = master copy/ScreenGenie/artifacts/visual/query-salon-live/marketing/latest.json",
      "/Users/dannybrooking/Documents/GitHub = master copy/ScreenGenie/artifacts/visual/query-salon-live/quick-login/latest.json"
    ]
  },
  "voltmeter": {
    "mode": "read_latest_or_run",
    "command": "cd '/Users/dannybrooking/Documents/GitHub = master copy/Voltmeter' && node src/cli.mjs --profile profiles/query-salon-live-runtime.json",
    "latest_run": "/Users/dannybrooking/Documents/GitHub = master copy/Voltmeter/state/latest-run.json",
    "fallback_runs_dir": "/Users/dannybrooking/Documents/GitHub = master copy/Voltmeter/runs"
  }
}
