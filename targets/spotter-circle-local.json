    "marketing",
    "install-surface",
    "app"
  ],
  "appTester": {
    "enabled": true,
    "kind": "pwa",
    "url": "http://127.0.0.1:4175/spotter/?source=fir&install=1",
    "install_contract": {
      "app_runtime_url": "http://127.0.0.1:4175/spotter/app/",
      "expected_start_url": "http://127.0.0.1:4175/spotter/app/"
    }
  },
  "max_attempts": 5,
  "preflight": {
    "screenGenie": {
      "requirements": [
        {
          "type": "http",
          "url": "http://127.0.0.1:4175",
          "path": "/spotter/",
          "expected_status": [
            200
          ]
        },
        {
          "type": "http",
          "url": "http://127.0.0.1:4175",
          "path": "/spotter/app/",
          "expected_status": [
            200
          ]
        }
      ]
    },
    "voltmeter": {
      "requirements": [
        {
          "type": "http",
          "url": "http://127.0.0.1:4175",
          "path": "/spotter/",
          "expected_status": [
            200
          ]
        },
        {
          "type": "http",
          "url": "http://127.0.0.1:4175",
          "path": "/spotter/app/",
          "expected_status": [
            200
          ]
        }
      ]
    }
  },
  "pointer": {
    "mode": "read_latest_or_run",
    "command": "cd '/Users/dannybrooking/Documents/GitHub = master copy/Pointer' && node src/cli.mjs --profile profiles/spotter-circle-local-passive.json",
    "latest_run": "/Users/dannybrooking/Documents/GitHub = master copy/Pointer/state/latest-run.json"
  },
  "screenGenie": {
    "mode": "flows_latest",
    "commands": [
      "cd '/Users/dannybrooking/Documents/GitHub = master copy/ScreenGenie' && npm run genie -- --app spotter-circle --flow marketing",
      "cd '/Users/dannybrooking/Documents/GitHub = master copy/ScreenGenie' && npm run genie -- --app spotter-circle --flow app"
    ],
    "latest_runs": [
